{
  "id": "faust_drive",
  "name": "Faust Drive",
  "abbrev": "FDR",
  "version": "0.1.0",
  "description": "Faust-authored stereo drive/tone/mix",
  "author": "Local",
  "ui": "ui.js",
  "ui_chain": "ui_chain.js",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": true,
    "midi_in": false,
    "midi_out": false,
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Faust Drive",
          "params": [
            { "key": "drive", "name": "Drive", "type": "float", "min": 0, "max": 1, "default": 0.3, "step": 0.01 },
            { "key": "tone",  "name": "Tone",  "type": "float", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
            { "key": "mix",   "name": "Mix",   "type": "float", "min": 0, "max": 1, "default": 1.0, "step": 0.01 },
            { "key": "level", "name": "Level", "type": "float", "min": 0, "max": 1, "default": 0.8, "step": 0.01 }
          ],
          "knobs": ["drive", "tone", "mix", "level"]
        }
      }
    }
  }
}
