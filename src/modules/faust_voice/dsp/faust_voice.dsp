// Faust source for the Faust-Voice sound generator.
//
// Canonical DSP source. faust_voice_faust.c is generated by
// `mise run gen-faust` and checked into the repo so the project builds
// without a Faust toolchain installed.
//
// Two groups of params:
//   * Control inputs driven by the C wrapper from MIDI:
//       freq  — Hz, set on note-on
//       gate  — 0 or 1, drives the ADSR
//       gain  — 0..1, scaled MIDI velocity
//   * User-facing params declared in module.json:
//       cutoff, resonance, attack, release, level
//
// The order of hslider declarations is irrelevant: the adapter captures
// zones by label via buildUserInterface, not by index.

import("stdfaust.lib");

// --- Control inputs (C-driven) ----------------------------------------------
freq = hslider("freq", 220.0, 16.0, 12544.0, 0.001);
gate = hslider("gate", 0.0, 0.0, 1.0, 1.0);
gain = hslider("gain", 0.8, 0.0, 1.0, 0.001);

// --- User params ------------------------------------------------------------
cutoff    = hslider("cutoff",    0.6,   0.0,   1.0, 0.01);
resonance = hslider("resonance", 0.3,   0.0,   1.0, 0.01);
attack    = hslider("attack",    0.01,  0.001, 1.0, 0.001);
release   = hslider("release",   0.3,   0.01,  4.0, 0.01);
level     = hslider("level",     0.7,   0.0,   1.0, 0.01);

// cutoff (0..1) -> 60..14000 Hz log
cutoffHz = 60.0 * pow(14000.0 / 60.0, cutoff);

// resonance (0..1) -> Q 0.5..18
qVal = 0.5 + resonance * 17.5;

// AR envelope (no decay/sustain — sustain held at 1 while gate is high)
env = en.adsr(attack, 0.0, 1.0, release, gate);

osc = os.sawtooth(freq);

// tanh saturation after the resonant filter keeps high-Q peaks bounded
// to [-1, 1] before the final level scale. Side benefit: more characterful.
mono = osc * env * gain : fi.resonlp(cutoffHz, qVal, 1.0) : ma.tanh : *(level);

process = mono <: _, _;
