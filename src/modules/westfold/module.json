{
  "id": "westfold",
  "name": "Westfold",
  "abbrev": "WFD",
  "version": "0.1.0",
  "description": "Compact West Coast voice with dual oscillator FM, wavefolder, and low-pass gate",
  "author": "Local",
  "ui": "ui.js",
  "ui_chain": "ui_chain.js",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Westfold",
          "list_param": "preset",
          "count_param": "preset_count",
          "name_param": "preset_name",
          "params": [
            { "key": "volume", "name": "Volume", "type": "float", "min": 0, "max": 1, "default": 0.75, "step": 0.01 },
            { "key": "ratio", "name": "Ratio", "type": "float", "min": 0.25, "max": 4, "default": 1.5, "step": 0.01 },
            { "key": "fm", "name": "FM", "type": "float", "min": 0, "max": 1, "default": 0.15, "step": 0.01 },
            { "key": "fold", "name": "Fold", "type": "float", "min": 0, "max": 1, "default": 0.35, "step": 0.01 },
            { "key": "lpg", "name": "LPG", "type": "float", "min": 0, "max": 1, "default": 0.55, "step": 0.01 },
            { "key": "drive", "name": "Drive", "type": "float", "min": 0, "max": 1, "default": 0.28, "step": 0.01 },
            { "key": "strike", "name": "Strike", "type": "float", "min": 0, "max": 1, "default": 0.45, "step": 0.01 },
            { "key": "chaos", "name": "Chaos", "type": "float", "min": 0, "max": 1, "default": 0.12, "step": 0.01 },
            { "key": "sustain", "name": "Sustain", "type": "float", "min": 0, "max": 1, "default": 0.25, "step": 0.01 },
            { "key": "decay", "name": "Decay", "type": "float", "min": 0.02, "max": 4, "default": 0.45, "step": 0.01 },
            { "key": "release", "name": "Release", "type": "float", "min": 0.02, "max": 6, "default": 0.8, "step": 0.01 },
            { "key": "bend_range", "name": "Bend", "type": "float", "min": 0, "max": 12, "default": 2, "step": 0.1 }
          ],
          "knobs": ["volume", "ratio", "fm", "fold", "lpg", "drive", "strike", "chaos", "sustain"]
        }
      }
    }
  }
}
