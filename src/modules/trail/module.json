{
  "id": "trail",
  "name": "Trail Delay",
  "abbrev": "TRL",
  "version": "0.2.0",
  "description": "Lush stereo delay: tempo-syncable, modulated, filtered feedback with reverb tail",
  "author": "Local",
  "ui": "ui.js",
  "ui_chain": "ui_chain.js",
  "dsp": "dsp.so",
  "api_version": 2,
  "component_type": "audio_fx",
  "capabilities": {
    "audio_out": true,
    "audio_in": true,
    "midi_in": false,
    "midi_out": false,
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Trail Delay",
          "list_param": "preset",
          "count_param": "preset_count",
          "name_param": "preset_name",
          "params": [
            { "key": "time", "name": "Time", "type": "float", "min": 0, "max": 1, "default": 0.12, "step": 0.01 },
            { "key": "sync", "name": "Sync", "type": "float", "min": 0, "max": 9, "default": 0, "step": 1 },
            { "key": "feedback", "name": "Feedback", "type": "float", "min": 0, "max": 0.88, "default": 0.22, "step": 0.01 },
            { "key": "tone", "name": "Tone", "type": "float", "min": 0, "max": 1, "default": 0.55, "step": 0.01 },
            { "key": "mod", "name": "Mod", "type": "float", "min": 0, "max": 1, "default": 0.2, "step": 0.01 },
            { "key": "width", "name": "Width", "type": "float", "min": 0, "max": 1, "default": 0.5, "step": 0.01 },
            { "key": "drive", "name": "Drive", "type": "float", "min": 0, "max": 1, "default": 0.15, "step": 0.01 },
            { "key": "space", "name": "Space", "type": "float", "min": 0, "max": 1, "default": 0.05, "step": 0.01 },
            { "key": "mix", "name": "Mix", "type": "float", "min": 0, "max": 1, "default": 0.18, "step": 0.01 }
          ],
          "knobs": ["time", "sync", "feedback", "tone", "mod", "width", "drive", "space", "mix"]
        }
      }
    }
  }
}
