{
  "id": "westfold",
  "name": "Westfold",
  "abbrev": "WF",
  "version": "0.1.0",
  "description": "Compact West Coast voice with dual oscillator FM, wavefolder, and low-pass gate",
  "author": "Local",
  "ui": "ui.js",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "label": "Westfold",
          "params": [
            { "id": 0, "key": "volume", "label": "Volume", "type": "float", "min": 0, "max": 1, "default": 0.75, "step": 0.01 },
            { "id": 1, "key": "ratio", "label": "Ratio", "type": "float", "min": 0.25, "max": 4, "default": 1.5, "step": 0.01 },
            { "id": 2, "key": "fm", "label": "FM", "type": "float", "min": 0, "max": 1, "default": 0.15, "step": 0.01 },
            { "id": 3, "key": "fold", "label": "Fold", "type": "float", "min": 0, "max": 1, "default": 0.35, "step": 0.01 },
            { "id": 4, "key": "lpg", "label": "LPG", "type": "float", "min": 0, "max": 1, "default": 0.55, "step": 0.01 },
            { "id": 5, "key": "decay", "label": "Decay", "type": "float", "min": 0.02, "max": 4, "default": 0.45, "step": 0.01 },
            { "id": 6, "key": "release", "label": "Release", "type": "float", "min": 0.02, "max": 6, "default": 0.8, "step": 0.01 },
            { "id": 7, "key": "bend_range", "label": "Bend", "type": "float", "min": 0, "max": 12, "default": 2, "step": 0.1 }
          ],
          "knobs": ["volume", "ratio", "fm", "fold"]
        }
      }
    }
  }
}
