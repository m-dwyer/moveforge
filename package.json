{
  "name": "moveforge",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bless-renders": "node scripts/check-renders.ts bless",
    "build:web": "vite build",
    "check-renders": "node scripts/check-renders.ts check",
    "check-stress": "node scripts/check-stress.ts",
    "dev": "vite",
    "test": "vitest run",
    "gen-faust": "node scripts/gen-faust.ts",
    "gen-ui-chain": "node scripts/gen-ui-chain.ts",
    "gen-params": "node scripts/gen-params.ts",
    "metrics": "node scripts/render-metrics.ts",
    "new-module": "node scripts/new-module.ts",
    "serve": "vite",
    "typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json",
    "validate": "node scripts/gen-params.ts --check && node scripts/gen-faust.ts --check && node scripts/gen-ui-chain.ts --check && node scripts/validate-params.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  }
}
