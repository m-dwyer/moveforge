{
  "name": "moveforge",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bless-renders": "node scripts/check-renders.ts bless",
    "build:web": "tsc -p web/tsconfig.json",
    "check-renders": "node scripts/check-renders.ts check",
    "dev": "node scripts/dev-web.ts",
    "emulator-test": "tsc -p web/tsconfig.json && node scripts/test-emulator.ts",
    "metrics": "node scripts/render-metrics.ts",
    "new-module": "node scripts/new-module.ts",
    "serve": "tsc -p web/tsconfig.json && node scripts/serve-web.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json",
    "validate": "node scripts/validate-params.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "playwright": "1.58.2",
    "typescript": "^5.8.0"
  }
}
